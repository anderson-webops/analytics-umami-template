# Copy this file to .env before running docker compose.
# If you use the bundled Postgres container, set DATABASE_URL so it matches
# POSTGRES_DB, POSTGRES_USER, and POSTGRES_PASSWORD below.

DATABASE_URL=
DATABASE_TYPE=postgresql
APP_SECRET=

POSTGRES_DB=umami
POSTGRES_USER=umami
POSTGRES_PASSWORD=

# Cypress integration tests read these from ../.env.
CYPRESS_umami_user=admin
CYPRESS_umami_password=
